# ═══════════════════════════════════════════════
# ANTIDOTE MISSION V3 — Configuration
# Fondée par KHEDIM BENYAKHLEF (BENY-JOE)
# ═══════════════════════════════════════════════

# === SERVEUR ===
NODE_ENV=production
PORT=10000

# === GROQ AI — ROTATION MULTI-MODÈLES ===
# Clé principale
GROQ_API_KEY=gsk_votre_cle_principale_ici

# Clés de rotation (séparées par virgule) pour max tokens
# Format: gsk_key1,gsk_key2,gsk_key3
GROQ_API_KEYS_ROTATION=gsk_key1,gsk_key2,gsk_key3

# === SÉCURITÉ ===
CORS_ORIGIN=*
JWT_SECRET=votre_secret_jwt_ultra_securise_ici
RATE_LIMIT_MAX=30

# === LOGS ===
LOG_LEVEL=info

# === BASE DE DONNÉES (optionnel) ===
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://host:port
